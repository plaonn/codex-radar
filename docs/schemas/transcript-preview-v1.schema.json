{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/plaonn/codex-radar/docs/schemas/transcript-preview-v1.schema.json",
  "title": "codex-radar transcript preview v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "version", "generated_at", "session_id", "limit", "messages"],
  "properties": {
    "contract": { "const": "codex-radar.transcript-preview" },
    "version": { "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,255}$" },
    "limit": { "type": "integer", "minimum": 1, "maximum": 200 },
    "messages": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/$defs/message" }
    }
  },
  "$defs": {
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "text"],
      "properties": {
        "role": { "enum": ["user", "assistant"] },
        "text": { "type": "string", "minLength": 1, "maxLength": 20000 }
      }
    }
  }
}
