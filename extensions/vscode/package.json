{
  "name": "codex-radar-vscode",
  "displayName": "Codex Radar",
  "description": "VS Code view for extension host-local codex-radar sessions.",
  "version": "0.2.0",
  "publisher": "plaonn",
  "license": "MIT",
  "homepage": "https://github.com/plaonn/codex-radar/tree/main/extensions/vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/plaonn/codex-radar.git",
    "directory": "extensions/vscode"
  },
  "bugs": {
    "url": "https://github.com/plaonn/codex-radar/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "codex",
    "radar",
    "remote",
    "sessions",
    "ssh"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onView:codexRadar.dashboard",
    "onCommand:codexRadar.refresh"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexRadar.refresh",
        "title": "Codex Radar: Refresh Sessions",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "Codex Radar",
      "properties": {
        "codexRadar.stateDir": {
          "type": "string",
          "default": "",
          "description": "Override codex-radar state directory. Empty uses CODEX_RADAR_HOME, XDG_STATE_HOME/codex-radar, or ~/.local/state/codex-radar."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexRadar",
          "title": "Codex Radar",
          "icon": "media/codex-radar.svg"
        }
      ]
    },
    "views": {
      "codexRadar": [
        {
          "id": "codexRadar.dashboard",
          "name": "Dashboard",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codexRadar.refresh",
          "when": "view == codexRadar.dashboard",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "package": "npx --yes @vscode/vsce package --out codex-radar-vscode-${npm_package_version}.vsix",
    "test": "node --test test/*.test.js"
  }
}
