{
  "name": "codex-radar-vscode",
  "displayName": "Codex Radar",
  "description": "Read-only VS Code view for extension host-local codex-radar sessions.",
  "version": "0.1.0",
  "publisher": "plaonn",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:codexRadar.sessions",
    "onCommand:codexRadar.refresh",
    "onCommand:codexRadar.filterStatus",
    "onCommand:codexRadar.previewTranscript",
    "onCommand:codexRadar.openInCodex"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexRadar.refresh",
        "title": "Codex Radar: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "codexRadar.filterStatus",
        "title": "Codex Radar: Filter by Status",
        "icon": "$(filter)"
      },
      {
        "command": "codexRadar.previewTranscript",
        "title": "Codex Radar: Preview Transcript",
        "icon": "$(open-preview)"
      },
      {
        "command": "codexRadar.openInCodex",
        "title": "Codex Radar: Open in Codex (Experimental)",
        "icon": "$(link-external)"
      }
    ],
    "configuration": {
      "title": "Codex Radar",
      "properties": {
        "codexRadar.stateDir": {
          "type": "string",
          "default": "",
          "description": "Override codex-radar state directory. Empty uses CODEX_RADAR_HOME, XDG_STATE_HOME/codex-radar, or ~/.local/state/codex-radar."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "codexRadar.sessions",
          "name": "Codex Radar"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codexRadar.filterStatus",
          "when": "view == codexRadar.sessions",
          "group": "navigation@1"
        },
        {
          "command": "codexRadar.refresh",
          "when": "view == codexRadar.sessions",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "codexRadar.previewTranscript",
          "when": "view == codexRadar.sessions && viewItem == codexRadar.session",
          "group": "inline@1"
        },
        {
          "command": "codexRadar.openInCodex",
          "when": "view == codexRadar.sessions && viewItem == codexRadar.session",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  }
}
