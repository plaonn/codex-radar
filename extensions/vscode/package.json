{
  "name": "codex-radar-vscode",
  "displayName": "Codex Radar",
  "description": "VS Code view for extension host-local codex-radar sessions.",
  "version": "0.1.11",
  "publisher": "plaonn",
  "license": "MIT",
  "homepage": "https://github.com/plaonn/codex-radar/tree/main/extensions/vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/plaonn/codex-radar.git",
    "directory": "extensions/vscode"
  },
  "bugs": {
    "url": "https://github.com/plaonn/codex-radar/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "codex",
    "radar",
    "remote",
    "sessions",
    "ssh"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onView:codexRadar.attentionList",
    "onView:codexRadar.projectList",
    "onView:codexRadar.hiddenList",
    "onCommand:codexRadar.refresh",
    "onCommand:codexRadar.filterStatus",
    "onCommand:codexRadar.configureRetention",
    "onCommand:codexRadar.pruneNow",
    "onCommand:codexRadar.hideSession",
    "onCommand:codexRadar.restoreSession",
    "onCommand:codexRadar.markRead",
    "onCommand:codexRadar.markUnread",
    "onCommand:codexRadar.openInCodex"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexRadar.refresh",
        "title": "Codex Radar: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "codexRadar.filterStatus",
        "title": "Codex Radar: Filter by Status",
        "icon": "$(filter)"
      },
      {
        "command": "codexRadar.configureRetention",
        "title": "Codex Radar: Configure Retention",
        "icon": "$(settings-gear)"
      },
      {
        "command": "codexRadar.pruneNow",
        "title": "Codex Radar: Prune Now",
        "icon": "$(trash)"
      },
      {
        "command": "codexRadar.openInCodex",
        "title": "Codex Radar: Open in Codex (Experimental)",
        "icon": "$(link-external)"
      },
      {
        "command": "codexRadar.hideSession",
        "title": "Codex Radar: Hide from Radar",
        "icon": "$(eye-closed)"
      },
      {
        "command": "codexRadar.restoreSession",
        "title": "Codex Radar: Restore to Radar",
        "icon": "$(eye)"
      },
      {
        "command": "codexRadar.markRead",
        "title": "Codex Radar: Mark as Read",
        "icon": "$(mail-read)"
      },
      {
        "command": "codexRadar.markUnread",
        "title": "Codex Radar: Mark as Unread",
        "icon": "$(mail)"
      }
    ],
    "configuration": {
      "title": "Codex Radar",
      "properties": {
        "codexRadar.stateDir": {
          "type": "string",
          "default": "",
          "description": "Override codex-radar state directory. Empty uses CODEX_RADAR_HOME, XDG_STATE_HOME/codex-radar, or ~/.local/state/codex-radar."
        },
        "codexRadar.cliPath": {
          "type": "string",
          "default": "codex-radar",
          "description": "codex-radar CLI executable path used for config and prune commands."
        },
        "codexRadar.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Python executable used only when Codex Radar falls back to a source checkout with src/codex_radar/cli.py in the current workspace."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexRadar",
          "title": "Codex Radar",
          "icon": "media/codex-radar.svg"
        }
      ]
    },
    "views": {
      "codexRadar": [
        {
          "id": "codexRadar.attentionList",
          "name": "Attention"
        },
        {
          "id": "codexRadar.projectList",
          "name": "Projects"
        },
        {
          "id": "codexRadar.hiddenList",
          "name": "Hidden",
          "visibility": "collapsed"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codexRadar.filterStatus",
          "when": "view == codexRadar.projectList",
          "group": "navigation@1"
        },
        {
          "command": "codexRadar.refresh",
          "when": "view == codexRadar.projectList",
          "group": "navigation@2"
        },
        {
          "command": "codexRadar.configureRetention",
          "when": "view == codexRadar.projectList",
          "group": "navigation@3"
        },
        {
          "command": "codexRadar.pruneNow",
          "when": "view == codexRadar.projectList",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "codexRadar.markRead",
          "when": "view == codexRadar.attentionList && viewItem == codexRadar.session.done.unread",
          "group": "inline@1"
        },
        {
          "command": "codexRadar.markUnread",
          "when": "view == codexRadar.attentionList && viewItem == codexRadar.session.done.read",
          "group": "inline@1"
        },
        {
          "command": "codexRadar.markRead",
          "when": "view == codexRadar.projectList && viewItem == codexRadar.session.done.unread",
          "group": "inline@1"
        },
        {
          "command": "codexRadar.markUnread",
          "when": "view == codexRadar.projectList && viewItem == codexRadar.session.done.read",
          "group": "inline@1"
        },
        {
          "command": "codexRadar.hideSession",
          "when": "view == codexRadar.attentionList && viewItem == codexRadar.session",
          "group": "inline@2"
        },
        {
          "command": "codexRadar.hideSession",
          "when": "view == codexRadar.attentionList && viewItem == codexRadar.session.done.unread",
          "group": "inline@2"
        },
        {
          "command": "codexRadar.hideSession",
          "when": "view == codexRadar.attentionList && viewItem == codexRadar.session.done.read",
          "group": "inline@2"
        },
        {
          "command": "codexRadar.hideSession",
          "when": "view == codexRadar.projectList && viewItem == codexRadar.session",
          "group": "inline@2"
        },
        {
          "command": "codexRadar.hideSession",
          "when": "view == codexRadar.projectList && viewItem == codexRadar.session.done.unread",
          "group": "inline@2"
        },
        {
          "command": "codexRadar.hideSession",
          "when": "view == codexRadar.projectList && viewItem == codexRadar.session.done.read",
          "group": "inline@2"
        },
        {
          "command": "codexRadar.restoreSession",
          "when": "view == codexRadar.hiddenList && viewItem == codexRadar.session.hidden",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "package": "npx --yes @vscode/vsce package --out codex-radar-vscode-${npm_package_version}.vsix",
    "test": "node --test test/*.test.js"
  }
}
