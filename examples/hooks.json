{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/YOUR_USER/.local/bin/codex-radar-hook",
            "timeout": 5,
            "statusMessage": "Indexing Codex session"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/YOUR_USER/.local/bin/codex-radar-hook",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/YOUR_USER/.local/bin/codex-radar-hook",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/YOUR_USER/.local/bin/codex-radar-hook",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/YOUR_USER/.local/bin/codex-radar-hook",
            "timeout": 5,
            "statusMessage": "Codex Radar noticed an approval request"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/YOUR_USER/.local/bin/codex-radar-hook",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
