{
  "name": "codex-radar-vscode",
  "displayName": "Codex Radar",
  "description": "Project-grouped Codex thread radar for VS Code.",
  "version": "0.4.9",
  "publisher": "plaonn",
  "license": "MIT",
  "homepage": "https://github.com/plaonn/codex-radar/tree/main/extensions/vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/plaonn/codex-radar.git",
    "directory": "extensions/vscode"
  },
  "bugs": {
    "url": "https://github.com/plaonn/codex-radar/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/codex-radar.png",
  "keywords": [
    "codex",
    "radar",
    "remote",
    "sessions",
    "ssh"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:codexRadar.attentionList",
    "onView:codexRadar.projectList",
    "onView:codexRadar.archivedList",
    "onCommand:codexRadar.refresh",
    "onCommand:codexRadar.openDashboard",
    "onCommand:codexRadar.filterStatus"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexRadar.refresh",
        "title": "Codex Radar: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "codexRadar.openDashboard",
        "title": "Codex Radar: Open Dashboard",
        "icon": "$(layout)"
      },
      {
        "command": "codexRadar.filterStatus",
        "title": "Codex Radar: Filter by Status",
        "icon": "$(filter)"
      }
    ],
    "configuration": {
      "title": "Codex Radar",
      "properties": {
        "codexRadar.stateDir": {
          "type": "string",
          "default": "",
          "description": "Override codex-radar state directory. Empty uses CODEX_RADAR_HOME, %LOCALAPPDATA%/codex-radar/state on Windows, or XDG_STATE_HOME/codex-radar and ~/.local/state/codex-radar on POSIX."
        },
        "codexRadar.codexExecutable": {
          "type": "string",
          "default": "",
          "description": "Path or command name for a separately installed Codex CLI on the extension host. Empty uses codex from PATH. Codex Radar does not bundle Codex."
        },
        "codexRadar.readSource": {
          "type": "string",
          "enum": [
            "observe",
            "direct",
            "export"
          ],
          "enumDescriptions": [
            "Keep the direct adapter effective while checking shared export semantic parity locally.",
            "Use only the legacy direct sessions.json and transcript adapters.",
            "Use the shared sanitized export contract, with the direct adapter as a one-release fallback."
          ],
          "default": "observe",
          "description": "Selects the VS Code read adapter during the shared-export migration. Observation is local and sends no telemetry."
        },
        "codexRadar.openThreadBehavior": {
          "type": "string",
          "enum": [
            "ask",
            "openWorkspace",
            "openHere"
          ],
          "enumDescriptions": [
            "Ask whether to open the session workspace or resume in the current window.",
            "Open the session working directory in a new window before resuming the thread.",
            "Resume the thread in the current window even when its workspace differs."
          ],
          "default": "ask",
          "description": "Controls Open in Codex only when the session working directory is outside the current VS Code workspace."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexRadar",
          "title": "Codex Radar",
          "icon": "media/codex-radar.svg"
        }
      ]
    },
    "views": {
      "codexRadar": [
        {
          "id": "codexRadar.attentionList",
          "name": "Attention",
          "type": "webview"
        },
        {
          "id": "codexRadar.projectList",
          "name": "Projects",
          "type": "webview"
        },
        {
          "id": "codexRadar.archivedList",
          "name": "Archived",
          "type": "webview",
          "visibility": "collapsed"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codexRadar.filterStatus",
          "when": "view == codexRadar.projectList",
          "group": "navigation@1"
        },
        {
          "command": "codexRadar.refresh",
          "when": "view == codexRadar.attentionList || view == codexRadar.projectList || view == codexRadar.archivedList",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "package": "npx --yes @vscode/vsce package --out codex-radar-vscode-${npm_package_version}.vsix",
    "test": "node --test test/*.test.js"
  }
}
